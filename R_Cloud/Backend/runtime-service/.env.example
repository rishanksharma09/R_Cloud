# ─────────────────────────────────────────────────────────────────
# R Agent Cloud — Runtime Service
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
# Environment: development | production | test
NODE_ENV=development

# Port the gRPC server listens on
# Deployment Service connects to this port (default: 50051)
GRPC_PORT=50051

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string
# Used to store runtime registry (runtimeId, runtimeUrl, status, health)
DATABASE_URL=postgresql://postgres:password@localhost:5432/rcloud

# ── Railway (Cloud Provider) ─────────────────────────────────────
# Railway API token — get it from railway.app → Account Settings → Tokens
# Used to create projects, deploy services, inject env vars
RAILWAY_API_TOKEN=your_railway_token_here

# Railway GraphQL API endpoint (do not change unless Railway changes it)
RAILWAY_API_URL=https://backboard.railway.com/graphql/v2

# ── NATS (Event Bus) ─────────────────────────────────────────────
# NATS server URL
# Runtime Service publishes events: runtime.started, runtime.failed, etc.
# AgentOps Service and Notification Service subscribe to these
NATS_URL=nats://localhost:4222

# ── Health Monitoring ─────────────────────────────────────────────
# How often (milliseconds) to poll every running runtime's /health endpoint
# Default: 30000 (30 seconds)
HEALTH_CHECK_INTERVAL_MS=30000

# How long (milliseconds) to wait for a /health response before timing out
# Default: 5000 (5 seconds)
HEALTH_CHECK_TIMEOUT_MS=5000

# Max number of automatic restart attempts before marking runtime as FAILED
# Default: 3
MAX_RESTART_ATTEMPTS=3

# ── Logging ──────────────────────────────────────────────────────
# Log level: debug | info | warn | error
# Use debug in development, info in production
LOG_LEVEL=info

# ── OpenTelemetry (Observability) ────────────────────────────────
# OTLP Collector endpoint — where traces and metrics are sent
# Leave empty to disable telemetry in development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name that appears in traces (do not change)
OTEL_SERVICE_NAME=runtime-service

# ── OTel Collector (for user agent tracing) ─────────────────────
# The central OTel collector that collects traces FROM user's Railway containers
# This is injected into every Railway deployment — not used by runtime-service itself
OTEL_COLLECTOR_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_COLLECTOR_AUTH_HEADER=Authorization=Basic <your-grafana-token>
