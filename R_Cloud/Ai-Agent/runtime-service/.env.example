# Runtime Service — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to git.

# ─── Railway ───────────────────────────────────────────
# API token to authenticate with Railway's GraphQL API
# Get from: https://railway.app/account/tokens
RAILWAY_API_TOKEN=

# ─── Database ──────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/runtime_service

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── NATS ──────────────────────────────────────────────
# NATS event bus connection URL
NATS_URL=nats://localhost:4222

# ─── gRPC Server ───────────────────────────────────────
# Port the gRPC server listens on (other services call this)
GRPC_PORT=50051

# ─── HTTP Health Server ────────────────────────────────
# Port for the simple HTTP /health endpoint (Railway pings this)
HTTP_PORT=3000

# ─── Health Monitoring ─────────────────────────────────
# How often to ping runtime /health endpoints (milliseconds)
HEALTH_CHECK_INTERVAL_MS=30000

# Maximum number of auto-restarts before marking a runtime as permanently failed
MAX_RESTART_ATTEMPTS=3

# Timeout for each /health ping (milliseconds)
HEALTH_CHECK_TIMEOUT_MS=5000

# ─── Internal Service Auth ─────────────────────────────
# Secret token that calling services must include in gRPC metadata
# Used by auth.interceptor to verify caller identity
INTERNAL_SERVICE_TOKEN=

# ─── OpenTelemetry ─────────────────────────────────────
OTEL_SERVICE_NAME=runtime-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── App ───────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
