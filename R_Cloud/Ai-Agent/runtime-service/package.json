{
  "name": "runtime-service",
  "version": "1.0.0",
  "description": "R Agent Cloud — Runtime Service. Provisions, manages, and monitors AI application runtimes on Railway.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "db:migrate": "drizzle-kit push",
    "proto:generate": "protoc --ts_out=./src/generated ./src/proto/runtime.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/instrumentation-grpc": "^0.48.0",
    "@opentelemetry/instrumentation-http": "^0.48.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "drizzle-orm": "^0.29.0",
    "nats": "^2.18.0",
    "pg": "^8.11.0",
    "pino": "^8.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "drizzle-kit": "^0.20.0",
    "jest": "^29.0.0",
    "pino-pretty": "^10.3.0",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  }
}
